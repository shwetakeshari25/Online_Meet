{
  "manifest_version": 3,
  "name": "Online Meet Copilot Helper",
  "version": "1.0.0",
  "description": "Syncs real Google Meet & Zoom participants, mic/cam states, and transcriptions to your Online_Meet Dashboard.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://*.zoomgov.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://*.zoom.us/wc/*",
        "https://*.zoomgov.com/wc/*"
      ],
      "js": [
        "lib/socket.io.min.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
